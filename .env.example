# Application
APP_ENV=development
APP_PORT=8080
APP_SECRET_KEY=your-32-char-secret-key-here-change-this
APP_BASE_URL=https://shop.dominicatechnologies.com

# Database
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=kiosk_db

# JWT
JWT_SECRET=your-jwt-secret-key-change-this-in-production
JWT_EXPIRY_HOURS=24

# CSRF
CSRF_SECRET=your-csrf-secret-key-32-chars-min

# M-Pesa Daraja API
MPESA_CONSUMER_KEY=your-consumer-key
MPESA_CONSUMER_SECRET=your-consumer-secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=your-passkey
MPESA_CALLBACK_URL=https://api.shop.dominicatechnologies.com/api/mpesa/callback
MPESA_ENV=sandbox

# Email — Google Workspace (smtp.gmail.com:587, STARTTLS)
# Generate an App Password at: myaccount.google.com > Security > App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-address@yourdomain.com
SMTP_PASSWORD=your-google-app-password
EMAIL_FROM=your-address@yourdomain.com
EMAIL_FROM_NAME=Kiosk Manager

# Celcom Africa SMS — https://developers.celcomafrica.com
CELCOM_AFRICA_API_KEY=your_celcom_api_key
CELCOM_AFRICA_PARTNER_ID=your_partner_id
CELCOM_AFRICA_SHORTCODE=your_shortcode
CELCOM_AFRICA_BASE_URL=https://sms.celcomafrica.com/api/services/sendsms/

# Rate Limiting
RATE_LIMIT_AUTH=5-M
RATE_LIMIT_API=100-M

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
